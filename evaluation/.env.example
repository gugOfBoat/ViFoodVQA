# ==============================
# ViFoodVQA Evaluation Config
# ==============================

# OpenAI-compatible API for gpt-5.2 / gpt-5.5 adapters.
# For the official OpenAI API, keep the default base URL below.
OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
OPENAI_COMPAT_API_KEY=your_openai_compatible_api_key_here

# Neo4j live KG connection used by KG retrieval strategies:
# hybrid, graph_only, vector_only, and bm25.
NEO4J_URI=neo4j+s://your-neo4j-host.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Optional Hugging Face token.
# Only needed for private/gated datasets or models.
HF_TOKEN=

# Optional local cache roots for Kaggle/Colab runs.
# Leave empty to use the platform defaults.
HF_HOME=
TRANSFORMERS_CACHE=
HF_DATASETS_CACHE=
